{
  "version": 2,
  "outputDirectory": "www",
  "cleanUrls": true,
  "routes": [
    {
      "src": "^/service-worker.js$",
      "headers": { "cache-control": "public, max-age=0, must-revalidate" },
      "dest": "/service-worker.js"
    },
    {
      "src": "^/assets/(js|css)/(.*)$",
      "headers": { "cache-control": "public, max-age=0, must-revalidate" },
      "dest": "/assets/$1/$2"
    },
    {
      "src": "^/assets/img/(.*)$",
      "headers": { "cache-control": "public, max-age=86400, must-revalidate" },
      "dest": "/assets/img/$1"
    },
    {
      "src": "/app",
      "headers": { "cache-control": "public, max-age=0, must-revalidate" },
      "dest": "/app.html"
    },
    {
      "src": "/pro",
      "headers": { "cache-control": "public, max-age=0, must-revalidate" },
      "dest": "/pro.html"
    },
    {
      "src": "/blog",
      "headers": { "cache-control": "public, max-age=0, must-revalidate" },
      "dest": "/blog.html"
    },
    {
      "src": "/privacy",
      "headers": { "cache-control": "public, max-age=0, must-revalidate" },
      "dest": "/privacy.html"
    },
    {
      "src": "/terms",
      "headers": { "cache-control": "public, max-age=0, must-revalidate" },
      "dest": "/terms.html"
    },
    {
      "src": "/about",
      "headers": { "cache-control": "public, max-age=0, must-revalidate" },
      "dest": "/about.html"
    },
    {
      "src": "/contact",
      "headers": { "cache-control": "public, max-age=0, must-revalidate" },
      "dest": "/contact.html"
    },
    {
      "handle": "filesystem"
    },
    {
      "src": "/(.*)",
      "dest": "/$1"
    }
  ]
}
